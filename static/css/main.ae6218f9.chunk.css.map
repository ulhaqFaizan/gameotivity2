/***********************************  Home  *********************************************/

.home {
  background-image: url("./images/home page bg.png");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 110%;
  width: 100%;
  height: auto;
  padding: 20px 0 50px 0;
  position: relative;
  z-index: 1;
}

.background {
  width: 110%;
  min-width: 470px;
  position: relative;
  bottom: 29px;
  filter: blur(15px) !important;
}

.home h1 {
  font-size: 4rem;
  margin: 0;
  display: inline;
}

.home-heading {
  position: relative;
  left: -3rem;
  color: #fff;
  width: 500px;
}

.home-text {
  position: relative;
  left: -3rem;
  color: #fff;
  padding: 20px 0;
  margin: 2rem 0;
  /* line-height: 18px; */
}

.home-text p {
  margin-bottom: 0.5rem;
}

.btn-flat {
  background-color: rgb(197, 6, 244, 0.1) !important;
  color: rgba(255, 255, 255, 0.7) !important;
  border: none !important;

}


.btn:hover {
  box-shadow: 0 0 10px 0.25rem #C506F4;
  border: none !important;
}

.home-button a {
  position: relative;
  display: inline-block;
  padding: 10px 20px;
  color: #C506F4;
  font-size: 16px;
  text-decoration: none;
  text-transform: uppercase;
  overflow: hidden;
  transition: .5s;
  letter-spacing: 4px
}

.home-button a:hover {
  background: #C506F4;
  color: #fff;
  border-radius: 5px;
  box-shadow: 0 0 5px #C506F4,
    0 0 25px #C506F4,
    0 0 50px #C506F4,
    0 0 100px #C506F4;
}

.home-button a span {
  position: absolute;
  display: block;
}

.home-button a span:nth-child(1) {
  top: 0;
  left: -100%;
  width: 100%;
  height: 2px;
  background: linear-gradient(90deg, transparent, #C506F4);
  animation: btn-anim1 1s linear infinite;
}

@keyframes btn-anim1 {
  0% {
    left: -100%;
  }

  50%,
  100% {
    left: 100%;
  }
}

.home-button a span:nth-child(2) {
  top: -100%;
  right: 0;
  width: 2px;
  height: 100%;
  background: linear-gradient(180deg, transparent, #C506F4);
  animation: btn-anim2 1s linear infinite;
  animation-delay: .25s
}

@keyframes btn-anim2 {
  0% {
    top: -100%;
  }

  50%,
  100% {
    top: 100%;
  }
}

.home-button a span:nth-child(3) {
  bottom: 0;
  right: -100%;
  width: 100%;
  height: 2px;
  background: linear-gradient(270deg, transparent, #C506F4);
  animation: btn-anim3 1s linear infinite;
  animation-delay: .5s
}

@keyframes btn-anim3 {
  0% {
    right: -100%;
  }

  50%,
  100% {
    right: 100%;
  }
}

.home-button a span:nth-child(4) {
  bottom: -100%;
  left: 0;
  width: 2px;
  height: 100%;
  background: linear-gradient(360deg, transparent, #C506F4);
  animation: btn-anim4 1s linear infinite;
  animation-delay: .75s
}

@keyframes btn-anim4 {
  0% {
    bottom: -100%;
  }

  50%,
  100% {
    bottom: 100%;
  }
}

